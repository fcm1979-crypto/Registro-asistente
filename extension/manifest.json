{
  "manifest_version": 3,
  "name": "Registro de la Propiedad Asistente",
  "short_name": "RP Asistente",
  "version": "0.3.6",
  "description": "Asistente para Registros de la Propiedad. Analiza escrituras, cruza Catastro, valida GML y calcula plazos. Prueba gratuita 30 días.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://ovc.catastro.meh.es/*",
    "https://www1.sedecatastro.gob.es/*",
    "https://registro-licencias.fcm1979.workers.dev/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "Registro de la Propiedad Asistente",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pdf.worker.min.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}